# Configuration Backend Undefined
# Copier ce fichier en .env et remplir les valeurs

# Claude API Key (obtenir sur https://console.anthropic.com/)
CLAUDE_API_KEY=your_claude_api_key_here
ADMIN_API_KEY=your_secure_admin_key_here

# Port du serveur (optionnel, par défaut 3000)
PORT=3000

# Budget mensuel API Claude (optionnel, par défaut 25$)
MONTHLY_BUDGET_LIMIT=25.00

# EmailJS pour alertes d'abus
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
